generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  googleId      String    @unique
  email         String    @unique
  name          String?
  devices       Device[]
  pairingCodes  PairingRequest[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Device {
  id            String    @id @default(cuid())
  name          String
  type          DeviceType
  tokenHash     String    @unique
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([tokenHash])
}

model PairingRequest {
  id            String    @id @default(cuid())
  code          String    @unique
  codeHash      String    @unique
  deviceName    String
  deviceType    DeviceType
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        PairingStatus @default(PENDING)
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  @@index([codeHash])
  @@index([expiresAt])
}

enum DeviceType {
  DESKTOP_WINDOWS
  DESKTOP_MAC
  MOBILE_IOS
  MOBILE_ANDROID
}

enum PairingStatus {
  PENDING
  COMPLETED
  EXPIRED
}
