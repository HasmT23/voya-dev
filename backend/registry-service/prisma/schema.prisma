generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  googleId         String    @unique
  email            String    @unique
  name             String?
  tier             Tier      @default(FREE)
  stripeCustomerId String?   @unique
  usage            Usage[]
  devices          Device[]
  pairingCodes     PairingRequest[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Usage {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  month         String    // "2026-03" format
  commandCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, month])
  @@index([userId, month])
}

model Device {
  id            String    @id @default(cuid())
  name          String
  type          DeviceType
  tokenHash     String    @unique
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([tokenHash])
}

model PairingRequest {
  id            String    @id @default(cuid())
  code          String    @unique
  codeHash      String    @unique
  deviceName    String
  deviceType    DeviceType
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        PairingStatus @default(PENDING)
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  @@index([codeHash])
  @@index([expiresAt])
}

enum Tier {
  FREE
  PRO
}

enum DeviceType {
  DESKTOP_WINDOWS
  DESKTOP_MAC
  MOBILE_IOS
  MOBILE_ANDROID
}

enum PairingStatus {
  PENDING
  COMPLETED
  EXPIRED
}
